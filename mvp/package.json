{
  "name": "kratai",
  "displayName": "kratai",
  "description": "ratai-mvp",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kratai-panel",
          "title": "Kratai",
          "icon": "$(graph)"
        }
      ]
    },
    "views": {
      "kratai-panel": [
        {
          "id": "kratai-actions",
          "name": "Actions"
        }
      ]
    },
    "commands": [
      {
        "command": "kratai.showFileSummary",
        "title": "Kratai: Show Git Changes"
      },
      {
        "command": "kratai.generateClassDiagram",
        "title": "Kratai: Generate Class Diagram"
      },
      {
        "command": "kratai.openClassDiagram",
        "title": "Generate Class Diagram",
        "icon": "$(graph)"
      },
      {
        "command": "kratai.openGitChanges",
        "title": "Show Git Changes",
        "icon": "$(git-compare)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
