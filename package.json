{
  "name": "kratai",
  "displayName": "kratai",
  "description": "Architecture as source of truth. Generate diagrams from your codebase, maintain architectural oversight while AI agents code, and eliminate expensive context dumps.",
  "version": "1.9.2",
  "publisher": "kratai-core",
  "icon": "icon_white.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kratai-desci/kratai"
  },
  "homepage": "https://kratai.com",
  "bugs": {
    "url": "https://github.com/kratai-desci/kratai/issues"
  },
  "keywords": [
    "class diagram",
    "sequence diagram",
    "uml",
    "visualization",
    "typescript",
    "javascript",
    "python",
    "php",
    "git diff",
    "code analysis",
    "multi-language"
  ],
  "galleryBanner": {
    "color": "#333333",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Visualization",
    "Programming Languages"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "bin": {
    "kratai-mcp": "./out/mcp/server.mjs"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kratai-panel",
          "title": "Kratai",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "kratai-panel": [
        {
          "id": "kratai-actions",
          "name": "Actions"
        }
      ]
    },
    "commands": [
      {
        "command": "kratai.showFileSummary",
        "title": "Kratai: Show Git Changes"
      },
      {
        "command": "kratai.generateClassDiagram",
        "title": "Kratai: Generate Class Diagram"
      },
      {
        "command": "kratai.showConfigPanel",
        "title": "Kratai: Class Diagram Configuration"
      },
      {
        "command": "kratai.openClassDiagram",
        "title": "Generate Class Diagram",
        "icon": "$(graph)"
      },
      {
        "command": "kratai.openGitChanges",
        "title": "Show Git Changes",
        "icon": "$(git-compare)"
      },
      {
        "command": "kratai.openCommunity",
        "title": "Community & Feedback",
        "icon": "$(comment-discussion)"
      }
    ],
    "mcpServerDefinitionProviders": [
      {
        "id": "kratai.mcpProvider",
        "label": "Kratai MCP Server"
      }
    ],
    "chatSkills": [
      {
        "path": "./skills/kratai/SKILL.md"
      }
    ],
    "chatParticipants": [
      {
        "id": "kratai.architect",
        "name": "kratai",
        "description": "Architecture-aware coding assistant. Maintains SRP, DRY, YAGNI, KISS principles. Uses kratai diagrams to understand codebase before coding.",
        "isSticky": true
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@vscode/extension-telemetry": "^1.5.2",
    "php-parser": "^3.6.0",
    "typescript": "^5.9.3"
  }
}
