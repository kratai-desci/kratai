{
	"compilerOptions": {
		"module": "Node16",
		"target": "ES2022",
		"outDir": "out",
		"lib": [
			"ES2022",
			"DOM"
		],
		"sourceMap": true,
		"rootDir": "src",
		"strict": true,
		"esModuleInterop": true,
		"types": [
			"node",
			"mocha"
		],
		"moduleResolution": "node16"
	},
	"exclude": [
		"test-fixtures/**/*",
		"src/test/unit/enrichment/**/fixtures/**/*.tsx",
		"src/test/unit/enrichment/**/fixtures/**/*.ts"
	]
}
